return {
  config = {
    -- Ruby file settings
    vim.api.nvim_create_autocmd('FileType', {
      pattern = 'ruby',
      callback = function()
        vim.bo.shiftwidth = 2
        vim.bo.tabstop = 2
        vim.bo.expandtab = true
      end,
    }),

    vim.api.nvim_create_autocmd('BufWritePre', {
      pattern = '*.rb',
      callback = function()
        vim.lsp.buf.format { async = false }
      end,
    }),
  },
}
